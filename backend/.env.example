# Copy to .env in this folder (backend/). Do not commit .env.

PORT=8080
NODE_ENV=development

# Public URLs (CORS + email templates)
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# MySQL
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost

# Auth (user + admin)
JWT_SECRET=change_me_user_jwt
ADMIN_JWT_SECRET=change_me_admin_jwt
# Optional: separate secret for refresh tokens (recommended in production). If unset, defaults to `${JWT_SECRET}.refresh`.
JWT_REFRESH_SECRET=
# Optional token lifetimes (JWT `expiresIn` strings)
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Email (e.g. Gmail app password)
EMAIL_USER=
EMAIL_PASSWORD=

# Google (server verifies tokens)
GOOGLE_CLIENT_ID=

# Optional branding in templates
FACEBOOK_URL=
TWITTER_URL=
INSTAGRAM_URL=
LOGO_URL=http://localhost:8080/static/image/STRIKETECH-1.png

# Optional SMTP for affiliate emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
