# Copy to .env or .env.local in this folder (frontend/). Do not commit real secrets.

# Browser-visible API base (must match where Express listens)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Shown on affiliate landing, headers, and admin copy (optional).
NEXT_PUBLIC_STORE_NAME=Our store
# Default commission % mentioned on the public affiliate page (optional).
NEXT_PUBLIC_AFFILIATE_COMMISSION_PCT=15

# Google Identity Services (Web). Use the same OAuth 2.0 Web client as backend GOOGLE_CLIENT_ID when applicable.
# In Google Cloud Console → APIs & Services → Credentials → your Web client:
# add Authorized JavaScript origins, e.g. http://localhost:3000 and your production URL.
# Leave empty to disable the Google button and avoid GSI console errors during local dev.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
